# Server
HOST=127.0.0.1
PORT=8000

# development | staging | production
ENVIRONMENT=development

# Max players per lobby before status becomes "full" (default: 2)
LOBBY_MAX_PLAYERS=2

# Comma-separated browser origins allowed to call this API (CORS preflight).
# Required when the Next.js app runs on another host/port than the API.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
